<?php
require_once "/usr/local/emhttp/plugins/dynamix/include/Helpers.php";
require_once "/usr/local/emhttp/plugins/dynamix/include/Wrappers.php";

$plugin = "komodo-periphery";
$cfg = parse_plugin_cfg($plugin);
$status = [];
$statusOutput = shell_exec("/usr/local/emhttp/plugins/komodo-periphery/scripts/status.sh 2>/dev/null");
if (is_string($statusOutput) && trim($statusOutput) !== "") {
    $status = parse_ini_string($statusOutput, false, INI_SCANNER_RAW) ?: [];
}

$message = "";
$messageType = "normal";
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['service_action'], $_POST['csrf_token']) && $_POST['csrf_token'] === $var['csrf_token']) {
    $action = $_POST['service_action'];
    $allowed = ['start', 'stop', 'restart'];
    if (in_array($action, $allowed, true)) {
        exec("/etc/rc.d/rc.komodo-periphery " . escapeshellarg($action) . " 2>&1", $cmdOutput, $code);
        $message = implode("\n", $cmdOutput);
        $messageType = $code === 0 ? "success" : "error";
        $statusOutput = shell_exec("/usr/local/emhttp/plugins/komodo-periphery/scripts/status.sh 2>/dev/null");
        if (is_string($statusOutput) && trim($statusOutput) !== "") {
            $status = parse_ini_string($statusOutput, false, INI_SCANNER_RAW) ?: [];
        }
    }
}

$running = ($status['running'] ?? 'no') === 'yes';
$publicKey = $status['public_key'] ?? '';
$pluginVersion = $status['plugin_version'] ?? 'unknown';
?>
