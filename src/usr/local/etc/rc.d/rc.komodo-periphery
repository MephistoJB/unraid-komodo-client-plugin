#!/bin/bash

PLUGIN="komodo-periphery"
BASE="/usr/local/emhttp/plugins/${PLUGIN}/scripts"

case "${1:-}" in
  start)
    exec "${BASE}/start.sh"
    ;;
  stop)
    exec "${BASE}/stop.sh"
    ;;
  restart)
    "${BASE}/stop.sh" || true
    exec "${BASE}/start.sh"
    ;;
  status)
    exec "${BASE}/status.sh"
    ;;
  install-init)
    exec "${BASE}/init.sh"
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status|install-init}"
    exit 1
    ;;
esac
